{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "beehaven-datafactory-trokoz"
		},
		"BlobStoragebeehaven_trokoz_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'BlobStoragebeehaven_trokoz'"
		},
		"DataLakebronze_trokoz_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'DataLakebronze_trokoz'"
		},
		"AzureSynapsetrokoz_properties_typeProperties_endpoint": {
			"type": "string",
			"defaultValue": "https://synapseanalyticstrokoz.dev.azuresynapse.net"
		},
		"DataLakebronze_trokoz_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://beehavendatalaketrokoz.dfs.core.windows.net/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "beehaven-datafactory-trokoz_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"BlobStoragebeehaven_trokoz_connectionString": {
						"value": "[parameters('BlobStoragebeehaven_trokoz_connectionString')]"
					},
					"DataLakebronze_trokoz_accountKey": {
						"value": "[parameters('DataLakebronze_trokoz_accountKey')]"
					},
					"AzureSynapsetrokoz_properties_typeProperties_endpoint": {
						"value": "[parameters('AzureSynapsetrokoz_properties_typeProperties_endpoint')]"
					},
					"DataLakebronze_trokoz_properties_typeProperties_url": {
						"value": "[parameters('DataLakebronze_trokoz_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}